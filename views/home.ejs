<!DOCTYPE html>
<html lang="en">
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1.0">
        <title>Document</title>
    </head>
    <body>
        <h1>Moji bodovi: <%= points %></h1>
          <a href="/logout">Logout</a>


        <h2>Dostupne nagrade</h2>

        <% rewards.forEach(r => { %>
            <div style="border:1px solid black; padding:10px; margin:10px;">
                <h3><%= r.naziv %></h3>
                <img src="<%= r.slika %>" width="100px">
                <p>Bodovi: <%= r.potrebni_bodovi %></p>

                <button onclick="openModal('<%= r.nagrada_id %>')">
                    Iskoristi
                </button>
            </div>
        <% }) %>

        <div id="modal" style="display:none; position:fixed; top:30%; left:40%; background:white; padding:20px; border:1px solid black;">
            <p>Sigurno želiš iskoristiti ovu nagradu?</p>

            <form id="redeemForm" method="POST">
                <button type="submit">DA, iskoristi</button>
            </form>

            <button onclick="closeModal()">Odustani</button>
        </div>

        <hr/>

        <!-- MASTER: kartica korisnika -->
        <h2>Moja kartica lojalnosti</h2>
        <p>Trenutni bodovi: <strong><%= points %></strong></p>

        <!-- DETAIL: iskorištene nagrade -->
        <h3>Iskorištene nagrade</h3>

        <% if (iskoristene.length === 0) { %>
        <p>Još nisi iskoristio/la nijednu nagradu.</p>
        <% } else { %>
        <table border="1" cellpadding="8">
            <thead>
            <tr>
                <th>Nagrada</th>
                <th>Bodovi</th>
                <th>Datum</th>
            </tr>
            </thead>
            <tbody>
            <% iskoristene.forEach(i => { %>
                <tr>
                <td><%= i.naziv %></td>
                <td><%= i.potrebni_bodovi %></td>
                <td><%= new Date(i.vrijeme).toLocaleDateString('hr-HR') %></td>
                </tr>
            <% }) %>
            </tbody>
        </table>
        <% } %>

        <script>
            function openModal(id) {
                document.getElementById("redeemForm").action = "/home/redeem/" + id;
                document.getElementById("modal").style.display = "block";
            }

            function closeModal() {
                document.getElementById("modal").style.display = "none";
            }
        </script>
    </body>
</html>