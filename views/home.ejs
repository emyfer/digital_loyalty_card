<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Moja kartica</title>
  <link rel="stylesheet" href="/style.css">
</head>
<body>

  <nav class="navbar">
    <div class="navbar-brand">Costumer</div>
    <div class="navbar-links">
      <a href="/logout">Odjava</a>
    </div>
  </nav>

  <div class="page-wrapper">

    <div style="margin-bottom:1rem;">
      <p style="font-size:.8rem;font-weight:600;text-transform:uppercase;letter-spacing:.08em;color:var(--text-muted);margin-bottom:.5rem;">Your points</p>
      <div class="points-display">
        <%= points %> <small>points</small>
      </div>
    </div>

    <div class="section-title">Available rewards</div>

    <% if (rewards.length === 0) { %>
      <div class="empty-state">
        No available rewards. Collect points.
      </div>
    <% } %>

    <% rewards.forEach(r => { %>
      <div class="reward-card">

        <img src="<%= r.slika %>"/>

        <div class="reward-card-info">
          <h3><%= r.naziv %></h3>
          <span class="points-badge"><%= r.potrebni_bodovi %> points</span>
        </div>

        <div class="reward-card-actions">
          <button
            class="btn btn-primary"
            style="font-size:.82rem; padding:.45rem 1rem;"
            onclick="openModal('<%= r.nagrada_id %>')"
          >
            Use
          </button>
        </div>

      </div>
    <% }) %>

    <div class="section-title">Used rewards</div>

    <% if (iskoristene.length === 0) { %>
      <div class="empty-state">
        No rewards used
      </div>
    <% } else { %>
      <div class="card" style="padding:0; overflow:hidden;">
        <table>
          <thead>
            <tr>
              <th>Reward</th>
              <th>Points</th>
              <th>Date</th>
            </tr>
          </thead>
          <tbody>
            <% iskoristene.forEach(i => { %>
              <tr>
                <td><%= i.naziv %></td>
                <td><span class="points-badge"><%= i.potrebni_bodovi %></span></td>
                <td style="color:var(--text-muted);font-size:.85rem;">
                  <%= new Date(i.vrijeme).toLocaleDateString('hr-HR') %>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    <% } %>

  </div>

  <div class="modal-overlay" id="redeemOverlay">
    <div class="modal" style="max-width:360px; text-align:center;">
      <h2 style="margin-bottom:.5rem;">DO you wanna use reward?</h2>
      <p class="confirm-sub" style="margin-bottom:1.5rem;">Points will be taken off</p>
      <form id="redeemForm" method="POST">
        <div class="modal-footer" style="justify-content:center;">
          <button type="button" class="btn btn-outline" onclick="closeModal()">Cancel</button>
          <button type="submit" class="btn btn-primary">Use reward</button>
        </div>
      </form>
    </div>
  </div>

  <script>
    function openModal(id) {
      document.getElementById("redeemForm").action = "/home/redeem/" + id;
      document.getElementById("redeemOverlay").classList.add("active");
    }
    function closeModal() {
      document.getElementById("redeemOverlay").classList.remove("active");
    }
    document.getElementById("redeemOverlay").addEventListener("click", function(e) {
      if (e.target === this) closeModal();
    });
  </script>

</body>
</html>
