<!DOCTYPE html>
<html lang="en">
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1.0">

        <title>QR Code</title>

        <link rel="stylesheet" href="/style.css">
    </head>
    <body>

        <nav class="navbar">
            <div class="navbar-brand">
                Bartender
            </div>

            <div class="navbar-links">
                <a href="/logout">Logout</a>
            </div>

        </nav>

        <div class="page-wrapper">

            <div class="card">

            <h1>Caffee managment</h1>

            <div class="cafe-actions">
                <form action="/qr_code/open" method="POST">
                <button class="btn btn-primary" type="submit">
                    Open caffee
                </button>

                </form>

                <form action="/qr_code/close" method="POST">
                <button class="btn btn-danger" type="submit">
                    ✕ Close caffee
                </button>

                </form>

            </div>

            </div>

            <div class="section-title">
                Active QR code
            </div>

            <% if (activeCode) { %>
            <div class="qr-wrapper">
                <div class="qr-box">
                <img
                    src="https://api.qrserver.com/v1/create-qr-code/?size=260x260&data=http://localhost:3000/home/scan?kod_id=<%= activeCode.kod_id %>">
                </div>

                <div class="card" style="text-align:center; width:100%; max-width:420px;">
                <div style="margin-top: 1 rem;">
                    <span class="points-badge">
                        Valid for 30 minutes
                    </span>

                </div>

                </div>

            </div>

            <% } else { %>

            <div class="empty-state card">
                <h2>No active coda</h2>
                <p style="margin-top:.5rem;">
                    Open caffe to get the QR code
                </p>

            </div>

            <% } %>

        </div>

    </body>
</html>