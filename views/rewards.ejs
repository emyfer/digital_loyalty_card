<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Admin</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css"/>
    <link rel="stylesheet" href="/style.css">
  </head>
  <body>

    <nav class="navbar">
      <div class="navbar-brand">Admin</div>
      <div class="navbar-links">
        <a href="/users">Users</a>
        <a href="/logout">Log out</a>
      </div>
    </nav>

    <div class="page-wrapper">

      <h1>Reward managment</h1>

      <div class="card" style="margin-bottom:2rem;">
        <h2 style="margin-bottom:1.2rem;">New reward</h2>
        <form action="/rewards/add" method="POST">
          <div class="add-form">
            <input type="text" name="naziv" placeholder="Reward name" required />
            <input type="text" name="slika" placeholder="image URL" required />
            <input type="number" name="potrebni_bodovi" placeholder="Points" required min="1" />
            <button type="submit" class="btn btn-primary">Add</button>
          </div>
        </form>
      </div>

      <div class="search-row">
        <form method="GET" action="/rewards" style="display:flex;gap:.5rem;width:100%;">
          <input
            type="text"
            name="search"
            placeholder="search rewards..."
            value="<%= search %>"
          />
          <button type="submit" class="btn btn-outline">Search</button>
        </form>
      </div>

      <div class="section-title">All rewards</div>

      <% if (rewards.length === 0) { %>
        <div class="empty-state">
          No rewards 
        </div>
      <% } %>

      <% rewards.forEach(r => { %>
        <div class="reward-card">

          <img src="<%= r.slika %>"/>

          <div class="reward-card-info">
            <h3><%= r.naziv %></h3>
            <span class="points-badge"><%= r.potrebni_bodovi %> points</span>
          </div>

          <div class="reward-card-actions">
            <button class="btn-icon"
              onclick="openEdit('<%= r.nagrada_id %>', '<%= r.naziv %>', '<%= r.slika %>', '<%= r.potrebni_bodovi %>')"
            ><i class="fa-solid fa-pencil"></i></button>

            <form action="/rewards/<%= r.nagrada_id %>?_method=DELETE" method="POST">
              <button type="submit" class="btn-icon danger"><i class="fa-solid fa-trash"></i></button>
            </form>
          </div>

        </div>
      <% }) %>

    </div>

    <div class="modal-overlay" id="editOverlay">
      <div class="modal">
        <h2>Update reward</h2>
        <form id="editForm" method="POST">

          <div class="form-group">
            <label>Name</label>
            <input type="text" name="naziv" id="editNaziv" required />
          </div>

          <div class="form-group">
            <label>Image Url</label>
            <input type="text" name="slika" id="editSlika" required />
          </div>

          <div class="form-group">
            <label>Points</label>
            <input type="number" name="potrebni_bodovi" id="editBodovi" required min="1" />
          </div>

          <div class="modal-footer">
            <button type="button" class="btn btn-outline" onclick="closeEdit()">Cancle</button>
            <button type="submit" class="btn btn-primary">Save</button>
          </div>

        </form>
      </div>
    </div>

    <script>
      function openEdit(id, naziv, slika, bodovi) {
        document.getElementById("editForm").action = "/rewards/" + id + "?_method=PUT";
        document.getElementById("editNaziv").value = naziv;
        document.getElementById("editSlika").value = slika;
        document.getElementById("editBodovi").value = bodovi;
        document.getElementById("editOverlay").classList.add("active");
      }
      function closeEdit() {
        document.getElementById("editOverlay").classList.remove("active");
      }
      document.getElementById("editOverlay").addEventListener("click", function(e) {
        if (e.target === this) closeEdit();
      });
    </script>

  </body>
</html>
